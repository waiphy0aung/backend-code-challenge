{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "jest.config.cjs"],
  "exclude": ["node_modules", "dist"]
}
